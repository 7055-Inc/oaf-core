                "key": "x-tts-access-token",
                "value": "{{access_token}}"
              }
            ],
            "url": {
              "raw": "{{tiktok_base_url}}/product/{{api_version}}/products/:product_id?app_key={{app_key}}&timestamp={{timestamp}}&access_token={{access_token}}&version={{api_version}}&sign={{signature}}",
              "host": ["{{tiktok_base_url}}"],
              "path": ["product", "{{api_version}}", "products", ":product_id"],
              "query": [
                {"key": "app_key", "value": "{{app_key}}"},
                {"key": "timestamp", "value": "{{timestamp}}"},
                {"key": "access_token", "value": "{{access_token}}"},
                {"key": "version", "value": "{{api_version}}"},
                {"key": "sign", "value": "{{signature}}"}
              ],
              "variable": [
                {"key": "product_id", "value": "YOUR_PRODUCT_ID"}
              ]
            },
            "description": "Gets details of a specific product"
          }
