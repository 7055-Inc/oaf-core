{
  "template_slug": "diagonal-shift",
  "template_name": "Diagonal Shift",
  "description": "Everything at a 15° angle with counter-rotated text. Dynamic, unconventional, and visually striking.",
  "version": "1.0.0",
  "author": "Artist Sites",
  "custom_fields": [
    {
