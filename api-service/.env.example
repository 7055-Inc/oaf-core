# API Service Environment Configuration
# 
# Non-secret config lives here. All secrets are loaded from GCP Secret Manager
# at runtime via loadSecrets.js. See docs/API_REFERENCE.md for details.
#
# To add/update secrets: use GCP Console > Secret Manager > staging-env-secrets
# Or run: node api-service/scripts/seed-secrets.js

NODE_ENV=production
API_GATEWAY_PORT=3013
API_VERSION=1.0.0
API_INSTANCE=staging

# Database
DB_HOST=10.128.0.31
DB_NAME=wordpress_import
DB_PORT=3306
DB_SSL=true

# SOP Catalog
SOP_DB_HOST=10.128.0.31
SOP_DB_NAME=brakebee_sop
SOP_DB_PORT=3306

# Firebase (public project config)
FIREBASE_PROJECT_ID=onlineartfestival-com

# SMTP (non-secret)
SMTP_HOST=send.smtp.com
SMTP_PORT=587
SMTP_FROM_EMAIL=welcome@brakebee.com
SMTP_FROM_NAME=Brakebee Staging

# URLs
API_BASE_URL=https://staging-api.brakebee.com
FRONTEND_URL=https://staging.brakebee.com
SMART_MEDIA_BASE_URL=https://staging-api.brakebee.com/api/v2/media/images
COOKIE_DOMAIN=.brakebee.com
CORS_ALLOWED_ORIGINS=https://staging.brakebee.com,https://staging-api.brakebee.com

# Staging DB
STAGING_DB_HOST=10.128.0.31
STAGING_DB_NAME=wordpress_import
STAGING_DB_PORT=3306

# Marketplace toggles
WALMART_ENV=sandbox
WAYFAIR_ENV=sandbox
ETSY_CALLBACK_URL=https://api.brakebee.com/api/v2/catalog/etsy/oauth/callback

# Misc
FILE_UPLOAD_NOTIFY_EMAIL=benjamin@brakebee.com
CHROMA_HOST=localhost
CHROMA_PORT=8000
CLICKHOUSE_URL=http://localhost:8123
DATABASE_NAME=behavior
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
MEDIA_BACKEND_URL=http://10.128.0.29:3001
